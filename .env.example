CONFLUENCE_BASE_URL=https://confluence.example.com
CONFLUENCE_AUTH_MODE=auto
# For basic auth:
# CONFLUENCE_USERNAME=user@example.com
# CONFLUENCE_PASSWORD=...
# or CONFLUENCE_TOKEN=...
# For bearer auth:
# CONFLUENCE_TOKEN=...

# Optional source filtering:
# CONFLUENCE_SPACE_KEYS=all            # all spaces (default when omitted)
# CONFLUENCE_SPACE_KEYS=ENG,DOCS
# CONFLUENCE_EXCLUDE_SPACE_KEYS=ARCHIVE
# CONFLUENCE_CQL=label = "public"
# CONFLUENCE_INCLUDE_ATTACHMENTS=true

IRONRAG_BASE_URL=http://localhost:19000
IRONRAG_API_TOKEN=change-me
# Keep legacy cursor metadata lookup short; mutation admission uses
# IRONRAG_MUTATION_TIMEOUT_SECONDS if you need to tune upload/replace/delete
# calls separately.
CURSOR_LIBRARY_LOOKUP_TIMEOUT_SECONDS=5
CURSOR_LIBRARY_LOOKUP_MAX_ROWS_PER_SWEEP=16
ADMIN_BEARER_TOKEN=change-me

RUN_MODE=poll
SYNC_INTERVAL_SECONDS=1800
SYNC_ITEM_TIMEOUT_SECONDS=300
IRONRAG_MUTATION_TIMEOUT_SECONDS=60
REAPER_LIST_TIMEOUT_SECONDS=60
